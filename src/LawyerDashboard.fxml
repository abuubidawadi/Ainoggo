<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0"
           stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="LawyerDashboardController">

    <children>

        <VBox prefHeight="650.0" prefWidth="1000.0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <!-- HEADER -->
          
            <AnchorPane prefHeight="80.0" prefWidth="1000.0"
            styleClass="header">
    <children>
        <ImageView fitHeight="60.0" fitWidth="100.0"
                   layoutX="50.0" layoutY="10.0"
                   pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@/images/logo_black_icon.png" />
            </image>
        </ImageView>

        <Label text="Ainoggo"
               layoutX="117.0" layoutY="20.0"
               style="-fx-font-size: 30px; -fx-font-family: 'Inter'; -fx-text-fill: black;" />

        <Label text="Lawyer Dashboard"
               layoutX="820.0" layoutY="24.0"
               style="-fx-font-size: 20px; -fx-font-family: 'Inter'; -fx-text-fill: black;" />
    </children>
</AnchorPane>

            <!-- MAIN -->
            <HBox VBox.vgrow="ALWAYS">

                <!-- LEFT -->
                <AnchorPane prefWidth="320.0"
                            style="-fx-background-color: #f7f7f7; -fx-border-color: #d9d9d9; -fx-border-width: 0 1 0 0;">
                    <children>

                        <VBox layoutX="20.0" layoutY="24.0" spacing="16.0" prefWidth="340.0">

                            <!-- Lawyer Profile + Logout -->
                            <HBox alignment="CENTER_LEFT" spacing="10.0" prefWidth="340.0">
                                <children>
                                    <Label text="Lawyer Profile"
                                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1f1f1f;" />

                                    <Region HBox.hgrow="ALWAYS" />

                                    <Button fx:id="logoutBtn"
                                            text="Logout"
                                            onAction="#logout"
                                            style="-fx-background-color: #c8102e; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 4;" />
                                </children>
                            </HBox>

                            <ImageView fx:id="lawyerImageView"
                                       fitHeight="140.0"
                                       fitWidth="140.0"
                                       preserveRatio="true">
                                <image>
                                    <Image url="@/images/logo_black_icon.png" />
                                </image>
                            </ImageView>

                            <Separator prefWidth="355.0" />

                            <VBox spacing="14.0"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #d9d9d9; -fx-border-radius: 14; -fx-padding: 20 20 20 20;">

                                <Label fx:id="nameLabel"
                                       text="Name: Ashikul Islam"
                                       style="-fx-font-size: 15px; -fx-text-fill: #222222;" />

                                <Label fx:id="emailLabel"
                                       text="Email: ashikul@gmail.com"
                                       style="-fx-font-size: 15px; -fx-text-fill: #222222;" />

                                <Label fx:id="phoneLabel"
                                       text="Phone: -"
                                       style="-fx-font-size: 15px; -fx-text-fill: #222222;" />

                                <Label fx:id="specializationLabel"
                                       text="Specialization: Civil Litigation"
                                       style="-fx-font-size: 15px; -fx-text-fill: #222222;" />

                                <Label fx:id="experienceLabel"
                                       text="Experience: 6 Years"
                                       style="-fx-font-size: 15px; -fx-text-fill: #222222;" />

                                <Label fx:id="barIdLabel"
                                       text="Bar ID: 1235"
                                       style="-fx-font-size: 15px; -fx-text-fill: #222222;" />

                                <Label fx:id="addressLabel"
                                       text="Address: Dhaka"
                                       style="-fx-font-size: 15px; -fx-text-fill: #222222;" />
                            </VBox>
                        </VBox>
                    </children>
                </AnchorPane>

                <!-- RIGHT -->
                <AnchorPane HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #fcfcfc;">
                    <children>

                        <VBox spacing="18.0"
                              AnchorPane.topAnchor="24.0"
                              AnchorPane.leftAnchor="18.0"
                              AnchorPane.rightAnchor="18.0"
                              AnchorPane.bottomAnchor="18.0">

                            <Label text="Appointments &amp; Sessions"
                                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1f1f1f;" />

                            <!-- Upcoming -->
                            <VBox spacing="10.0">
                                <children>
                                    <Label text="Upcoming Appointments"
                                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2a2a2a;" />

                                    <ScrollPane fitToWidth="true"
                                                prefHeight="250.0"
                                                style="-fx-background-color: transparent;">
                                        <content>
                                            <VBox fx:id="upcomingContainer"
                                                  spacing="12.0"
                                                  style="-fx-background-color: #f3f3f3; -fx-padding: 10;">
                                            </VBox>
                                        </content>
                                    </ScrollPane>
                                </children>
                            </VBox>

                            <!-- Previous -->
                            <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                                <children>
                                    <Label text="Previous Sessions"
                                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2a2a2a;" />

                                    <ScrollPane fitToWidth="true"
                                                VBox.vgrow="ALWAYS"
                                                style="-fx-background-color: transparent;">
                                        <content>
                                            <VBox fx:id="previousContainer"
                                                  spacing="12.0"
                                                  style="-fx-background-color: #f3f3f3; -fx-padding: 10;">
                                            </VBox>
                                        </content>
                                    </ScrollPane>
                                </children>
                            </VBox>

                        </VBox>
                    </children>
                </AnchorPane>

            </HBox>

        </VBox>

    </children>
</AnchorPane>